# 复制为 .env 后按需修改；未设置的项都有安全的默认行为。

# 数据目录（数据库、旧版 JSON 等），默认 backend/data
INNERVOICE_DATA_DIR=

# 上传文件目录，默认在数据目录下的 uploads，可单独指到别的磁盘/路径
INNERVOICE_UPLOAD_DIR=

# 后端监听端口，默认 8000
INNERVOICE_PORT=

# JWT 签名密钥。留空则首次启动自动生成并持久化到 <数据目录>/.jwt_secret，
# 生产环境建议自己设置一个足够随机的值。
JWT_SECRET=

# 初始账户用户名，仅在数据库里还没有任何用户时生效，默认 admin
APP_DEFAULT_USERNAME=

# 初始账户密码。留空则首次启动自动生成随机密码并打印到日志（登录后请尽快在设置页修改）。
APP_DEFAULT_PASSWORD=

# AI 服务的 API Key（也可以在设置页里填写，此处优先级更高）
AI_API_KEY=

# access token / refresh token 有效期（分钟 / 天）
ACCESS_TOKEN_MINUTES=
REFRESH_TOKEN_DAYS=
